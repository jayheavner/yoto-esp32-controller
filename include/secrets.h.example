#pragma once
// ---------------------------------------------------------------------------
// secrets.h — COMPILE-TIME SEEDS (copy this file to `secrets.h` and fill in).
//
//   cp include/secrets.h.example include/secrets.h
//
// `secrets.h` is gitignored and must never be committed. These values are only
// FIRST-BOOT defaults: once you save settings on the device (grown-ups screen
// or the web portal at http://yoto-controller.local/settings) the NVS copy wins,
// so you can re-point a flashed board at new WiFi / new Yoto credentials in the
// field without reflashing. See include/app_config.h for how each is consumed.
// ---------------------------------------------------------------------------

// ---- WiFi (2.4 GHz only — the ESP32-S3 has no 5 GHz radio) ----
#define WIFI_SSID            "your-2.4GHz-ssid"
#define WIFI_PASSWORD        "your-wifi-password"

// ---- Yoto OAuth (confidential client: id + secret) ----
// Register an app at https://yoto.dev to get these. The flow used here is
// authorization-code + PKCE (run `python3 oauth_login.py` once to mint the
// refresh token, then seed it onto the board via the web portal's
// "paste a refresh token" field — the board owns the rotating token chain).
#define YOTO_CLIENT_ID       "your-yoto-client-id"
#define YOTO_CLIENT_SECRET   "your-yoto-client-secret"

// ---- Target player ----
// The deviceId of the Yoto Player this panel controls.
// Find it via GET /device-v2/devices/mine (see README / yoto.dev).
#define YOTO_DEVICE_ID       "your-yoto-device-id"

// ---- OTA / web-portal auth ----
// Basic-auth password for ElegantOTA uploads and the settings portal.
// Leave as "" to disable auth (empty string => no auth, checked via sizeof>1).
#define OTA_PASSWORD         ""
